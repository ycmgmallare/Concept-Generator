# Copy this file to ".env" and fill in your key.
# Kie AI API key — get one at https://kie.ai/api-keys
KIE_AI_API_KEY=your-kie-ai-key-here

# Optional: port for the local server (default 3000)
# PORT=3000

# --- Trend Finder (eBay) ---
# eBay Browse API keys — create a free Production keyset at https://developer.ebay.com
# (App ID = Client ID, Cert ID = Client Secret). Used to fetch live eBay products.
EBAY_CLIENT_ID=your-ebay-app-id-here
EBAY_CLIENT_SECRET=your-ebay-cert-id-here

# --- Trend Finder Upgrade ---
# Google Gemini (AI Studio) key — free at https://aistudio.google.com/apikey
# Used only for reading/summarising article text (never images).
GEMINI_API_KEY=your-gemini-key-here
# Optional model override (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
